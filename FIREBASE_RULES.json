{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin'",
        ".write": "$uid === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin'",
        ".validate": "newData.hasChildren(['email', 'role', 'createdAt'])",
        "email": {
          ".validate": "newData.isString() && newData.val().matches(/^[^@]+@[^@]+\\.[a-z]+$/)"
        },
        "role": {
          ".validate": "newData.val() === 'admin' || newData.val() === 'karyawan'"
        },
        "createdAt": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    "bookings": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["userId", "status", "startDate", "createdAt"],
      "$bookingId": {
        ".validate": "newData.hasChildren(['userId', 'carId', 'status', 'startDate', 'endDate'])",
        "status": {
          ".validate": "newData.val() === 'pending' || newData.val() === 'confirmed' || newData.val() === 'completed' || newData.val() === 'cancelled'"
        },
        "userId": {
          ".validate": "newData.isString()"
        },
        "carId": {
          ".validate": "newData.isString()"
        },
        "startDate": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "endDate": {
          ".validate": "newData.isNumber() && newData.val() > 0"
        },
        "totalPrice": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      }
    },
    "cars": {
      ".read": "auth != null",
      ".write": "root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["status", "type"],
      "$carId": {
        ".validate": "newData.hasChildren(['name', 'plate', 'status'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "plate": {
          ".validate": "newData.isString() && newData.val().matches(/^[A-Z]{1,2}\\s?\\d{1,4}\\s?[A-Z]{1,3}$/)"
        },
        "status": {
          ".validate": "newData.val() === 'tersedia' || newData.val() === 'disewa' || newData.val() === 'servis' || newData.val() === 'nonaktif'"
        },
        "odometer": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        }
      }
    },
    "customers": {
      ".read": "auth != null",
      ".write": "auth != null || root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["name", "phone", "email"],
      "$customerId": {
        ".validate": "newData.hasChildren(['name', 'phone'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0"
        },
        "phone": {
          ".validate": "newData.isString() && newData.val().matches(/^\\+?[0-9]{10,15}$/)"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().matches(/^[^@]+@[^@]+\\.[a-z]+$/)"
        }
      }
    },
    "reports": {
      ".read": "root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["month", "year"]
    },
    "backups": {
      ".read": "root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": ["timestamp"]
    }
  }
}
